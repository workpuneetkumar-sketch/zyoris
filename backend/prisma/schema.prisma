generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id            String                   @id @default(cuid())
  name          String
  slug          String                   @unique
  isActive      Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  users         User[]
  members       OrganizationMembership[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  deals         Deal[]
  revenues      Revenue[]
  expenses      Expense[]
  marketing     MarketingSpend[]
  inventories   Inventory[]
  chatSessions  ChatSession[]
  leads         Lead[]
  savedFilters  SavedFilter[]
}

model OrganizationMembership {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  roleId         String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([organizationId, userId])
  @@index([organizationId, roleId])
  @@index([userId])
}

model RefreshToken {
  id             String    @id @default(cuid())
  organizationId String?
  userId         String
  tokenHash      String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, organizationId])
  @@index([expiresAt])
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  password                String
  name                    String
  role                    Role                     @relation(fields: [roleId], references: [id])
  roleId                  String
  organizationId          String?
  organization            Organization?            @relation(fields: [organizationId], references: [id])
  designation             String?
  companyName             String?
  companyAbout            String?
  businessType            String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  auditLogs               AuditLog[]
  chatSessions            ChatSession[]
  memberships             OrganizationMembership[]
  refreshTokens           RefreshToken[]
  assignedLeads           Lead[]                   @relation("LeadAssignedTo")
  createdLeadNotes        LeadNote[]               @relation("LeadNoteCreatedBy")
  leadActivities          LeadActivity[]           @relation("LeadActivityCreatedBy")
  leadAssignments         LeadAssignment[]         @relation("LeadAssignmentAssignedBy")
  savedLeadFilters        SavedFilter[]
  assignedLeadAssignments LeadAssignment[]         @relation("LeadAssignmentAssignedTo")

  @@index([organizationId])
}

model AuditLog {
  id             String        @id @default(cuid())
  user           User?         @relation(fields: [userId], references: [id])
  userId         String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  action         String
  metadata       Json?
  createdAt      DateTime      @default(now())

  @@index([organizationId, createdAt])
}

model Role {
  id          String                   @id @default(cuid())
  name        String                   @unique
  description String?
  users       User[]
  memberships OrganizationMembership[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
}

model Deal {
  id             String         @id @default(cuid())
  organizationId String?
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  externalId     String?        @unique
  sourceSystem   String
  name           String
  stage          String
  amount         Float
  currency       String
  closeDate      DateTime?
  owner          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  snapshots      DealSnapshot[]

  @@index([organizationId, stage])
  @@index([organizationId, createdAt])
}

model DealSnapshot {
  id       String   @id @default(cuid())
  deal     Deal     @relation(fields: [dealId], references: [id])
  dealId   String
  asOfDate DateTime
  stage    String
  amount   Float
  currency String
}

model Revenue {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  externalId     String?       @unique
  sourceSystem   String
  date           DateTime
  amount         Float
  currency       String
  segment        String?
  createdAt      DateTime      @default(now())

  @@index([organizationId, date])
}

model Expense {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  externalId     String?       @unique
  sourceSystem   String
  date           DateTime
  amount         Float
  currency       String
  category       String?
  createdAt      DateTime      @default(now())

  @@index([organizationId, date])
}

model MarketingSpend {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  externalId     String?       @unique
  sourceSystem   String
  date           DateTime
  channel        String
  campaign       String?
  amount         Float
  currency       String
  createdAt      DateTime      @default(now())

  @@index([organizationId, date])
}

model Inventory {
  id             String              @id @default(cuid())
  organizationId String?
  organization   Organization?       @relation(fields: [organizationId], references: [id])
  externalId     String?             @unique
  sourceSystem   String
  sku            String
  name           String
  quantity       Int
  safetyStock    Int
  unitCost       Float
  currency       String
  createdAt      DateTime            @default(now())
  snapshots      InventorySnapshot[]

  @@index([organizationId, createdAt])
}

model InventorySnapshot {
  id          String    @id @default(cuid())
  inventory   Inventory @relation(fields: [inventoryId], references: [id])
  inventoryId String
  asOfDate    DateTime
  quantity    Int
}

model ForecastSnapshot {
  id           String   @id @default(cuid())
  metric       String
  horizonDays  Int
  asOfDate     DateTime
  forecastJson Json
}

model Recommendation {
  id              String   @id @default(cuid())
  type            String
  title           String
  description     String
  confidence      Float
  financialImpact Float
  justification   String
  createdAt       DateTime @default(now())
  metadata        Json?
}

model ChatSession {
  id             String        @id @default(cuid())
  userId         String
  organizationId String?
  user           User          @relation(fields: [userId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  title          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  messages       ChatMessage[]

  @@index([organizationId, updatedAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id])
  role      String
  content   String
  provider  String?
  model     String?
  createdAt DateTime    @default(now())
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

enum LeadActivityType {
  CREATED
  STATUS_CHANGED
  NOTE_ADDED
  ASSIGNED
  UPDATED
}

model Lead {
  id             String              @id @default(cuid())
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  phone          String?
  email          String?
  company        String?
  city           String?
  source         String?
  status         LeadStatus          @default(NEW)
  assignedToId   String?
  assignedTo     User?               @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  tags           LeadTag[]
  notes          LeadNote[]
  activities     LeadActivity[]
  statusHistory  LeadStatusHistory[]
  assignments    LeadAssignment[]

  @@index([organizationId, status])
  @@index([organizationId, assignedToId])
  @@index([organizationId, createdAt])
  @@index([email])
  @@index([phone])
}

model LeadTag {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  label     String
  createdAt DateTime @default(now())

  @@unique([leadId, label])
  @@index([label])
}

model LeadNote {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("LeadNoteCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  note        String
  createdAt   DateTime @default(now())

  @@index([leadId, createdAt])
}

model LeadActivity {
  id          String           @id @default(cuid())
  leadId      String
  lead        Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        LeadActivityType
  message     String
  createdById String?
  createdBy   User?            @relation("LeadActivityCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  metadata    Json?
  createdAt   DateTime         @default(now())

  @@index([leadId, createdAt])
  @@index([type])
}

model LeadStatusHistory {
  id         String      @id @default(cuid())
  leadId     String
  lead       Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStatus LeadStatus?
  toStatus   LeadStatus
  changedAt  DateTime    @default(now())

  @@index([leadId, changedAt])
}

model LeadAssignment {
  id           String @id @default(cuid())
  leadId       String
  lead         Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedToId String
  assignedTo   User   @relation("LeadAssignmentAssignedTo", fields: [assignedToId], references: [id], onDelete: Restrict)

  assignedById String?
  assignedBy   User?   @relation("LeadAssignmentAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)

  assignedAt DateTime @default(now())

  @@index([leadId, assignedAt])
  @@index([assignedToId])
}

model SavedFilter {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  filterJson     Json
  isShared       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, userId])
}
